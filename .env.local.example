# ── Povinné pre spustenie ─────────────────────────────────────
# Supabase (service key — server-side only, obchádza RLS)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=

# Anthropic / Claude API (story + prompt + DNA generovanie)
ANTHROPIC_API_KEY=

# App base URL (produkcia: https://<app>.vercel.app)
APP_URL=http://localhost:3000

# ── Auth pre crony a server-to-server volania ─────────────────
# POZOR: keď chýba, chránené routes sú OTVORENÉ (fail-open, fix v M1).
# Vercel crony ho posielajú automaticky ako Bearer; cron-job.org ako ?secret=
CRON_SECRET=

# ── Generovanie médií ─────────────────────────────────────────
# Google AI Studio — Nano Banana 2/Pro + Veo (PRIMÁRNY generátor)
GOOGLE_API_KEY=

# Higgsfield Cloud API — Soul V2 (intimate fallback + Fanvue sety + character sheet)
# Formát: KEY_ID:KEY_SECRET
HIGGSFIELD_API_KEY=

# fal.ai — FLUX LoRA fallback + Kling/Seedance video
FAL_API_KEY=

# BFL — Black Forest Labs (FLUX.2 multi-reference, voliteľný fallback)
BFL_API_KEY=

# ── Publikovanie ──────────────────────────────────────────────
# Instagram Graph API (posting + import-insights cron)
IG_ACCESS_TOKEN=
IG_USER_ID=

# YouTube OAuth (reels) — refresh token získaš cez /api/auth/youtube
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── Fanvue (monetizácia) — OAuth only, žiadne API kľúče ───────
# App vytvoríš vo Fanvue Builder area; redirect URI:
#   {APP_URL}/api/auth/fanvue/callback
# Tokeny sa po autorizácii cez /api/auth/fanvue ukladajú do DB (chs_oauth_tokens).
FANVUE_CLIENT_ID=
FANVUE_CLIENT_SECRET=
# Voliteľné — default: offline_access read:self read:fan read:insights write:post write:media write:chat-message
# FANVUE_SCOPES=

# ── Legacy / voliteľné ────────────────────────────────────────
# GitHub Actions dispatch (starý Higgsfield workflow; token: repo + workflow scope)
GH_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=character-studio
